{
  "name": "pglife",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:deep": "eslint --config eslint.deep.config.mjs src",
    "type-check": "tsc --noEmit",
    "type-check:strict": "tsc --noEmit --strict --noUnusedLocals --noUnusedParameters --noImplicitReturns --noFallthroughCasesInSwitch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:debug": "playwright test --debug",
    "scan:quick": "node scripts/true-deep-scan.js --quick",
    "scan:deep": "node scripts/true-deep-scan.js",
    "scan:code": "node scripts/deep-code-reviewer.js",
    "scan:pre-launch": "node scripts/pre-launch-deep-scan.js",
    "scan:pre-launch:quick": "node scripts/pre-launch-deep-scan.js --quick",
    "scan:verify": "node scripts/verify-deep-scan-setup.js",
    "analyze:deps": "madge --circular --extensions ts,tsx src",
    "analyze:duplication": "jscpd src --min-lines 5 --min-tokens 50",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "scan:sast": "semgrep --config=auto --severity=ERROR --severity=WARNING src/",
    "scan:sast:json": "semgrep --config=auto --json --output=deep-scan-reports/semgrep.json src/"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.45.0",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "next": "^14.2.35",
    "next-auth": "^4.24.11",
    "prisma": "^5.22.0",
    "razorpay": "^2.9.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jscpd": "^4.0.8",
    "madge": "^8.0.0",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
