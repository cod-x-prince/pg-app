# ─── DATABASE (Supabase) ────────────────────────────────────────────────────
# Get this from: supabase.com → Settings → Database → Connection string
# Transaction mode (with connection pooler)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:6543/postgres?pgbouncer=true"
# Direct connection (for migrations)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# ─── NEXTAUTH ──────────────────────────────────────────────────────────────
# Any random 32+ char string. Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Optional - for social login)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── CLOUDINARY (Images & Videos) ──────────────────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# ─── RAZORPAY (Payments) ───────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
# Use test keys for development (rzp_test_), live keys for production (rzp_live_)
RAZORPAY_KEY_ID="rzp_test_xxxxxx"
RAZORPAY_KEY_SECRET="your-secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxx"

# ─── RESEND (Emails) ───────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxx"

# ─── CLOUDFLARE TURNSTILE (CAPTCHA) ─────────────────────────────────────────
# Get from: dash.cloudflare.com → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4xxxxxxxxxxx"
TURNSTILE_SECRET_KEY="0x4xxxxxxxxxxx"

# ─── UPSTASH REDIS (Rate Limiting) ──────────────────────────────────────────
# Get from: upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token-here"

# ─── SENTRY (Error Monitoring - Optional) ───────────────────────────────────
# Get from: sentry.io → Create Project → Next.js → DSN
NEXT_PUBLIC_SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_DSN="https://xxx@sentry.io/xxx"
