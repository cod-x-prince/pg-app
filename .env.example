# ─── DATABASE (Supabase) ────────────────────────────────────────────────────
# Get this from: supabase.com → Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# ─── NEXTAUTH ──────────────────────────────────────────────────────────────
# Any random 32+ char string. Generate at: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─── CLOUDINARY (Images & Videos) ──────────────────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# ─── RAZORPAY (Payments) ───────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
NEXT_PUBLIC_RAZORPAY_KEY_ID=""

# ─── RESEND (Emails) ───────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# ─── GOOGLE MAPS ───────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → Maps JavaScript API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# ─── ADMIN ─────────────────────────────────────────────────────────────────
# The email address that will be the admin account
ADMIN_EMAIL="admin@pglife.in"

# ─── UPSTASH REDIS (Rate Limiting) ──────────────────────────────────────────
# Get from: upstash.com → Create Database → REST API
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ─── SENTRY (Error Monitoring) ──────────────────────────────────────────────
# Get from: sentry.io → Create Project → Next.js → DSN
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
SENTRY_DSN="https://...@sentry.io/..."
SENTRY_ORG="your-org-slug"
SENTRY_PROJECT="pglife"
# Get auth token from: sentry.io → Settings → Auth Tokens
# Required for source map uploads (readable stack traces in Sentry)
SENTRY_AUTH_TOKEN="sntrys_..."
