generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  phone        String?
  passwordHash String
  role         Role       @default(TENANT)
  isApproved   Boolean    @default(false)
  avatar       String?
  whatsapp     String?
  kycDocUrl    String?
  licenseUrl   String?
  kycStatus    KycStatus  @default(NONE)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  properties   Property[]
  bookings     Booking[]
  reviews      Review[]
  likes        Like[]
}

model Property {
  id          String     @id @default(cuid())
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  name        String
  description String
  city        String
  address     String
  lat         Float?
  lng         Float?
  gender      Gender     @default(UNISEX)
  whatsapp    String?
  houseRules  String?    @db.Text
  foodPlan    FoodPlan   @default(NONE)
  neighbourhood String?
  isVerified  Boolean    @default(false)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  rooms       Room[]
  images      Image[]
  videos      Video[]
  amenities   Amenity[]
  bookings    Booking[]
  reviews     Review[]
  likes       Like[]

  @@index([city])
  @@index([isActive])
  @@index([gender])
  @@index([ownerId])
  @@index([city, isActive])
  @@index([city, isActive, gender])
  @@index([createdAt])
}

model Room {
  id          String    @id @default(cuid())
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  type        String
  rent        Int
  deposit     Int
  isAvailable  Boolean   @default(true)
  availableFrom DateTime?
  bookings     Booking[]

  @@index([propertyId])
  @@index([propertyId, isAvailable])
}

model Booking {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     User          @relation(fields: [tenantId], references: [id])
  propertyId String
  property   Property      @relation(fields: [propertyId], references: [id])
  roomId     String
  room       Room          @relation(fields: [roomId], references: [id])
  type       BookingType   @default(ENQUIRY)
  status     BookingStatus @default(PENDING)
  moveInDate DateTime
  tokenPaid  Boolean       @default(false)
  razorpayId String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([tenantId])
  @@index([propertyId])
  @@index([roomId])
  @@index([tenantId, status])
}

model Review {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     User     @relation(fields: [tenantId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  @@unique([tenantId, propertyId])
  @@index([propertyId])
}

model Image {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  url        String
  isPrimary  Boolean  @default(false)

  @@index([propertyId])
}

model Video {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  url        String

  @@index([propertyId])
}

model Amenity {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  name       String

  @@index([propertyId])
  @@index([name])
}

model Like {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([propertyId])
}

enum Role {
  TENANT
  OWNER
  BROKER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum BookingType {
  ENQUIRY
  DIRECT
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum FoodPlan {
  NONE
  BREAKFAST
  TWO_MEALS
  THREE_MEALS
  CUSTOM
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}
